{
    "name": "yiisoft/yii2-app-advanced",
    "description": "Activemedia Mobile Application Manager",
    "keywords": [
        "yii2",
        "framework",
        "advanced",
        "project template"
    ],
    "homepage": "http://www.yiiframework.com/",
    "type": "project",
    "license": "BSD-3-Clause",
    "support": {
        "issues": "https://github.com/yiisoft/yii2/issues?state=open",
        "forum": "http://www.yiiframework.com/forum/",
        "wiki": "http://www.yiiframework.com/wiki/",
        "irc": "irc://irc.freenode.net/yii",
        "source": "https://github.com/yiisoft/yii2"
    },
    "minimum-stability": "stable",
    "require": {
        "php": ">=7.2",
        "yiisoft/yii2": "~2.0.5",
        "yiisoft/yii2-bootstrap": "~2.0.0",
        "yiisoft/yii2-swiftmailer": "~2.0.0",
        "yiisoft/yii2-jui": "~2.0.0",
        "yiisoft/yii2-redis": "~2.0.0",
        "yiisoft/yii2-imagine": "~2.0.0",
        "yiisoft/yii2-mongodb": "~2.1.0",
        "codemix/yii2-localeurls": "^1.2",
        "kartik-v/yii2-mpdf": "^1.0",
        "2amigos/qrcode-library": "~1.0",
        "guzzlehttp/guzzle": "*",
        "vlucas/phpdotenv": "^2.3",
        "intervention/image": "^2.3",
        "trntv/yii2-aceeditor": "*",
        "nkovacs/yii2-datetimepicker": "dev-master",
        "evert/sitemap-php": "^1.2",
        "understeam/yii2-fcm": "~0.1",
        "yii2mod/yii2-chosen-select": "*",
        "himiklab/yii2-recaptcha-widget": "*",
        "trntv/yii2-datetime-widget": "^1.1",
        "trntv/yii2-file-kit": "^1.3",
        "2amigos/yii2-tinymce-widget": "^1.1",
        "2amigos/yii2-selectize-widget": "^1.1",
        "2amigos/yii2-editable-widget": "^1.1",
        "2amigos/yii2-gallery-widget": "^1.1",
        "2amigos/yii2-taggable-behavior": "^1.0",
        "maksyutin/yii2-mediaelement": "dev-master",
        "2amigos/yii2-file-upload-widget": "~1.0",
        "kartik-v/bootstrap-fileinput": "@dev",
        "kartik-v/yii2-widget-fileinput": "@dev",
        "lav45/yii2-translated-behavior": "^1.4",
        "yiisoft/yii2-queue": "^2.0",
        "jeremeamia/superclosure": "^2.3",
        "abraham/twitteroauth": "^0.7.4",
        "wbraganca/yii2-dynamicform": "*",
        "unclead/yii2-multiple-input": "~2.0",
        "nirvana-msu/yii2-infinite-scroll": "@dev",
        "yiimaker/yii2-social-share": "^1.4",
        "tinymce/tinymce": "4.7.4",
        "kartik-v/yii2-date-range": "dev-master",
        "wbraganca/yii2-fancytree-widget": "^1.0",
        "phpoffice/phpspreadsheet": "^1.3",
        "telegram-bot/api": "^2.3",
        "longman/telegram-bot": "^0.53.0",
      "ext-soap": "*"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "~2.0.0",
        "yiisoft/yii2-gii": "~2.0.0",
        "yiisoft/yii2-faker": "~2.0.0",
        "codeception/base": "^2.2.3",
        "codeception/verify": "~0.3.1"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "config": {
        "process-timeout": 1800,
        "fxp-asset": {
            "enabled": false
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "scripts": {
        "post-install-cmd": [
            "yii\\composer\\Installer::postInstall"
        ],
        "post-create-project-cmd": [
            "yii\\composer\\Installer::postCreateProject",
            "yii\\composer\\Installer::postInstall"
        ]
    },
    "extra": {
        "yii\\composer\\Installer::postCreateProject": {
            "setPermission": [
                {
                    "runtime": "0777",
                    "backend/web/assets": "0777",
                    "static": "0777",
                    "yii": "0755"
                }
            ]
        },
        "yii\\composer\\Installer::postInstall": {
            "copyFiles": [
                {
                    ".env.example": ".env"
                }
            ]
        },
        "asset-installer-paths": {
            "bower-asset-library": "vendor/bower",
            "npm-asset-library": "vendor/npm"
        }
    }
}
